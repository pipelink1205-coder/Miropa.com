APP_NAME="Mi Ropa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://marketplace.test
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@miropa.com"
MAIL_FROM_NAME="${APP_NAME}"

# Beta/producción — ejemplo con SMTP genérico (Mailtrap, Resend, etc.):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Marketplace ---
# Activar checkout con pasarela real (false hasta integrar Wompi/Mercado Pago)
MARKETPLACE_CHECKOUT_ENABLED=false

# OAuth — inicio con redes (Google / Facebook)
# Google: https://console.cloud.google.com/ → Credenciales OAuth → redirect: {APP_URL}/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Facebook: https://developers.facebook.com/ → App → Facebook Login → redirect: {APP_URL}/auth/facebook/callback
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# Microsoft (Hotmail, Outlook, Live): https://portal.azure.com/ → App registrations → redirect: {APP_URL}/auth/microsoft/callback
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=common
# Apple: https://developer.apple.com/ → Sign in with Apple → Services ID → redirect: {APP_URL}/auth/apple/callback
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=storage/app/apple/AuthKey_XXXXX.p8

# Twilio (verificación SMS en producción)
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=

# Producción recomendado:
# APP_DEBUG=false
# DB_CONNECTION=mysql
# MAIL_MAILER=smtp
# FILESYSTEM_DISK=s3
# QUEUE_CONNECTION=redis
# SCOUT_DRIVER=meilisearch
